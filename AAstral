local function IsTrialPriorityActive()
    return State.AutoJoinTrial or State.AutoExitTrial or State.TrialEnabled
end

local function CanRunGamemode(mode)
    local activeMode = GetCurrentVisibilityGamemode()

    if activeMode == "Trial" then
        return mode == "Trial"
    end

    if mode == "Defense" then
        if IsTrialPriorityActive() then
            return false
        end
        if activeMode == "Raid" then
            return false
        end
        if State.AutoJoinRaid or State.RaidAutoFarm then
            return false
        end
        return State.AutoJoinDefense or State.AutoDefense
    end

    if mode == "Raid" then
        if IsTrialPriorityActive() then
            return false
        end
        if activeMode == "Defense" then
            return false
        end
        if State.AutoJoinDefense or State.AutoDefense then
            return false
        end
        return State.AutoJoinRaid or State.RaidAutoFarm
    end

    return true
end

local function CheckTrialExit()
    if not IsTrialGuiActive() then
        warn("[Trial Exit] TrialGui no está activo")
        return false
    end

    local currentRoom = GetCurrentTrialRoom()
    if not currentRoom then
        warn("[Trial Exit] No se encontró PlayerGui.TrialGui.Main.Room")
        return false
    end

    if not State.ExitWave then
        warn("[Trial Exit] No se configuró la room de salida")
        return false
    end

    local desiredRoom = NormalizeWaveValue(State.ExitWave)
    local currentRoomNumber = NormalizeRoomNumber(currentRoom)
    local desiredRoomNumber = NormalizeRoomNumber(State.ExitWave)

    if currentRoomNumber and desiredRoomNumber then
        if currentRoomNumber < desiredRoomNumber then
            warn("[Trial Exit] Room actual: " .. tostring(currentRoomNumber) .. ", buscando: " .. tostring(desiredRoomNumber))
            return false
        end
    elseif currentRoom ~= desiredRoom then
        warn("[Trial Exit] Room actual: " .. tostring(currentRoom) .. ", buscando: " .. tostring(desiredRoom))
        return false
    end

    if FireWorldTeleport(State.ExitTeleporter) then
        print("[Trial Exit Debug] Teleportando por remote event a Worlds[" .. tostring(State.ExitTeleporter) .. "]")
        return true
    end

    warn("[Trial Exit] No se pudo teleportar por remote event a Worlds[" .. tostring(State.ExitTeleporter) .. "]")
    return false
end

