local function GetAliveEnemies()
    local list = {}
    if not State.SelectedMap or not State.SelectedEnemy then return list end

    local worlds = Workspace:FindFirstChild("Worlds")
    local map = worlds and worlds:FindFirstChild(State.SelectedMap)
    local folder = map and map:FindFirstChild("Enemies")
    if not folder then return list end

    for _, enemy in ipairs(folder:GetChildren()) do
        if enemy:IsA("Model") and enemy.Name == State.SelectedEnemy and enemy:FindFirstChild("HumanoidRootPart") then
            local isDead = enemy:GetAttribute("EnemyDead")
            if isDead ~= true then
                table.insert(list, enemy)
            end
        end
    end
    return list
end

