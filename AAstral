local function BuildStarsDeletePayload(rarity)
    local rankOrder = {"Mythical", "Legendary", "Epic", "Rare", "Uncommon", "Common"}
    local payload = {}
    local shouldDelete = false

    for _, rank in ipairs(rankOrder) do
        if rank == rarity then
            shouldDelete = true
        end
        if shouldDelete then
            payload[rank] = "delete"
        end
    end

    return payload
end

local function FireStars()
    local world = State.StarsWorld
    local rarity = State.StarsRarity
    if not world or not rarity then
        warn("[Stars] Selecciona World y Rareza antes de enviar")
        return
    end

    local deletePayload = BuildStarsDeletePayload(rarity)
    local args = {
        [1] = {
            [1] = {
                ["__BridgeTuplePayload__"] = true,
                ["Payload"] = {
                    [1] = world,
                    [2] = deletePayload,
                    ["n"] = 2,
                },
            },
            [2] = "\\"
        }
    }

    local bridge = ReplicatedStorage:FindFirstChild("BridgeNet2")
    local remote = bridge and bridge:FindFirstChild("dataRemoteEvent")
    if remote and typeof(remote.FireServer) == "function" then
        print("[Stars] Enviando stars a " .. tostring(world) .. " con rareza " .. tostring(rarity))
        remote:FireServer(unpack(args))
    else
        warn("[Stars] Remote no encontrado")
    end
end

