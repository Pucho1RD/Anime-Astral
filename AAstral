local function IsRaidGuiActive()
    local gui = LocalPlayer:FindFirstChild("PlayerGui")
    local raidGui = gui and gui:FindFirstChild("RaidGui")
    if not raidGui then
        return false
    end

    if raidGui.Enabled == true then
        return true
    end
    if typeof(raidGui.GetAttribute) == "function" and raidGui:GetAttribute("Enabled") == true then
        return true
    end

    local data = raidGui:FindFirstChild("Data")
    if data then
        local enabledChild = data:FindFirstChild("Enabled")
        if enabledChild and enabledChild:IsA("BoolValue") and enabledChild.Value == true then
            return true
        end
        if typeof(data.GetAttribute) == "function" and data:GetAttribute("Enabled") == true then
            return true
        end
    end

    return false
end

local function TryStartRaidWithGui()
    local gui = LocalPlayer:FindFirstChild("PlayerGui")
    if IsRaidGuiActive() then
        print("[Raid Join] RaidGui ya está activo, se omite el intento de unión")
        return false
    end

    local windows = gui and gui:FindFirstChild("Windows")
    local raidTemplate = windows and windows:FindFirstChild("RaidTemplate")

    if not raidTemplate then
        warn("[Raid Join] No se encontró RaidTemplate")
        return false
    end

    -- Hacer visible
    raidTemplate.Visible = true
    print("[Raid Join Debug] RaidTemplate hecho visible")
    task.wait(0.3)

    -- Buscar el botón Start
    local main = raidTemplate:FindFirstChild("Main")
    local actions = main and main:FindFirstChild("Actions")
    local startButton = actions and actions:FindFirstChild("Start")
    if not startButton then
        startButton = actions and actions:FindFirstChildWhichIsA("GuiButton", true)
    end

    if startButton and startButton:IsA("GuiObject") then
        local absPos = startButton.AbsolutePosition
        local absSize = startButton.AbsoluteSize
        local centerPos = Vector2.new(absPos.X + absSize.X / 0.90, absPos.Y + absSize.Y / 0.9)
        print("[Raid Join Debug] Botón Start encontrado, Name:", startButton.Name, "ClassName:", startButton.ClassName, "AbsolutePosition:", absPos, "Size:", absSize, "ClickCenter:", centerPos)

        pcall(function()
            if typeof(startButton.Activate) == "function" then
                startButton:Activate()
            end
        end)

        SimulateGuiClick(startButton, absPos)

        local activated = false
        local startTime = os.clock()
        local timeout = 2
        repeat
            if IsRaidGuiActive() then
                activated = true
                break
            end
            task.wait(0.15)
        until (os.clock() - startTime) > timeout

        if activated then
            print("[Raid Join] RaidGui activado tras click Start")
        else
            warn("[Raid Join] No se detectó activación de RaidGui tras click Start (timeout)")
        end
    else
        warn("[Raid Join] No se encontró Players.LocalPlayer.PlayerGui.Windows.RaidTemplate.Main.Actions.Start")
    end

    -- Ocultar de nuevo
    task.wait(0.2)
    raidTemplate.Visible = false
    print("[Raid Join Debug] RaidTemplate ocultado")
    return true
end

