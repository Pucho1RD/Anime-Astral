local function GetSelectedTeleporterPart(selectedWorld)
    local worlds = Workspace:FindFirstChild("Worlds")
    if not worlds or not selectedWorld then return nil end

    local world = worlds:FindFirstChild(selectedWorld)
    local teleporter = world and world:FindFirstChild("Teleporter")
    if not teleporter then
        warn("[Trial Exit] No se encontró Teleporter en Worlds[" .. tostring(selectedWorld) .. "]")
        return nil
    end

    if teleporter:IsA("BasePart") then
        local attr = teleporter:GetAttribute("TeleportTo")
        if typeof(attr) == "string" then
            local expectedWorld = tostring(selectedWorld)
            local prefix = expectedWorld .. "/"
            if string.sub(attr, 1, #prefix) ~= prefix then
                warn("[Trial Exit] Teleporter TeleportTo no coincide con el mundo seleccionado: " .. tostring(attr))
            end
        end
        print("[Trial Exit Debug] Teleporter directo encontrado: " .. teleporter.Name .. " en Worlds[" .. tostring(selectedWorld) .. "]")
        return teleporter
    end

    local teleporterPart = teleporter:FindFirstChildWhichIsA("BasePart", true)
    if teleporterPart then
        local attr = teleporterPart:GetAttribute("TeleportTo")
        if typeof(attr) == "string" then
            local expectedWorld = tostring(selectedWorld)
            local prefix = expectedWorld .. "/"
            if string.sub(attr, 1, #prefix) ~= prefix then
                warn("[Trial Exit] Teleporter Part TeleportTo no coincide con el mundo seleccionado: " .. tostring(attr))
            end
        end
        print("[Trial Exit Debug] Teleporter part encontrado: " .. teleporterPart.Name .. " en Worlds[" .. tostring(selectedWorld) .. "]")
        return teleporterPart
    end

    warn("[Trial Exit] No se encontró ningún BasePart dentro de Teleporter en Worlds[" .. tostring(selectedWorld) .. "]")
    return nil
end

local function NormalizeWaveValue(value)
    local text = tostring(value or "")
    local digits = text:match("(%d+)")
    return digits or text
end

local function NormalizeRoomNumber(value)
    local normalized = NormalizeWaveValue(value)
    return tonumber(normalized)
end

