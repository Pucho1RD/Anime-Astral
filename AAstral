local function GetPlayerVisibilityContext()
    if typeof(LocalPlayer.GetAttribute) == "function" then
        local attr = LocalPlayer:GetAttribute("VisibilityContext")
        if type(attr) == "string" and attr ~= "" then
            return attr
        end
    end

    local contextValue = LocalPlayer:FindFirstChild("VisibilityContext")
    if contextValue and type(contextValue.Value) == "string" and contextValue.Value ~= "" then
        return contextValue.Value
    end

    return nil
end

local PrevTrialActive = false

local function GetCurrentVisibilityGamemode()
    local context = GetPlayerVisibilityContext()
    if type(context) ~= "string" or context == "" then
        return nil
    end

    if string.match(context, "^Trial") or string.find(context, "Trial") or string.find(context, "TimeTrial") then
        return "Trial"
    end
    if string.match(context, "^Defense") or string.find(context, "Defense") then
        return "Defense"
    end
    if string.match(context, "^Raid") or string.find(context, "Raid") then
        return "Raid"
    end

    return nil
end

local function GetCurrentWorldContext()
    local context = GetPlayerVisibilityContext()
    if type(context) ~= "string" or context == "" then
        return nil
    end

    if string.match(context, "^World:?%d+") then
        return context
    end

    return nil
end

local function SendLoadoutRemote(selection, requireWorldContext)
    if type(selection) ~= "string" or selection == "" then
        warn("[Loadout] Selección inválida")
        return false
    end

    if requireWorldContext then
        local worldContext = GetCurrentWorldContext()
        if not worldContext then
            warn("[Loadout] BackToWorld solo funciona en World:1, World:2, World:3, World:4")
            return false
        end
    else
        local gamemode = GetCurrentVisibilityGamemode()
        if not gamemode then
            warn("[Loadout] Gamemode Loadout solo funciona dentro de un gamemode")
            return false
        end
    end
    --LOADOUT REMOTE 
    local args = {
        [1] = {
            [1] = selection,
            [2] = "?"
        }
    }

    local bridge = ReplicatedStorage:FindFirstChild("BridgeNet2")
    local remote = bridge and bridge:FindFirstChild("dataRemoteEvent")
    if remote and typeof(remote.FireServer) == "function" then
        remote:FireServer(unpack(args))
        print("[Loadout] Enviado:", selection, requireWorldContext and "(BackToWorld)" or "(Gamemode Loadout)")
        return true
    end

    warn("[Loadout] Remote no encontrado")
    return false
end

local LoadoutLoopToken = 0
local BackToWorldLoopToken = 0

local function StartLoadoutLoop()
    LoadoutLoopToken += 1
    local token = LoadoutLoopToken
    local lastSent = nil

    task.spawn(function()
        while token == LoadoutLoopToken do
            local selection = State.SelectedLoadout
            if selection and selection ~= "" then
                local mode = GetCurrentVisibilityGamemode()
                if mode then
                    local currentKey = "Loadout:" .. mode .. ":" .. selection
                    if lastSent ~= currentKey then
                        if SendLoadoutRemote(selection, false) then
                            lastSent = currentKey
                        end
                    end
                else
                    lastSent = nil
                end
            else
                lastSent = nil
            end

            task.wait(1)
        end
    end)
end

local function StartBackToWorldLoop()
    BackToWorldLoopToken += 1
