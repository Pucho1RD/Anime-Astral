local function IsEnemyGone(enemy)
    if not enemy or not enemy.Parent or not enemy:FindFirstChild("HumanoidRootPart") then
        return true
    end
    local isDead = enemy:GetAttribute("EnemyDead")
    return isDead == true
end

local function IsEnemyFinished(enemy)
    return IsEnemyGone(enemy)
end

