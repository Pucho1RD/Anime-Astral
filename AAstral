local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Workspace = game:GetService("Workspace")
local LocalPlayer = Players.LocalPlayer

local State = {
    SelectedMap = nil,
    SelectedEnemy = nil,
    AutofarmEnabled = false,
    AutoJoinTrial = false,
    TrialEnabled = false,
    AutoExitTrial = false,
    ExitWave = nil,
    ExitTeleporter = nil,
}

local function GetMaps()
    local list = {}
    local worlds = Workspace:FindFirstChild("Worlds")
    if not worlds then return list end

    for _, map in ipairs(worlds:GetChildren()) do
        if map:IsA("Folder") or map:IsA("Model") then
            table.insert(list, map.Name)
        end
    end

    table.sort(list)
    return list
end

local function GetEnemies(mapName)
    local list = {}
    local worlds = Workspace:FindFirstChild("Worlds")
    local map = worlds and worlds:FindFirstChild(mapName)
    local folder = map and map:FindFirstChild("Enemies")
    if not folder then return list end

    local seen = {}
    for _, enemy in ipairs(folder:GetChildren()) do
        if enemy:IsA("Model") and enemy:FindFirstChild("HumanoidRootPart") then
            local name = enemy.Name
            if not seen[name] then
                table.insert(list, name)
                seen[name] = true
            end
        end
    end

    table.sort(list)
    return list
end

local function GetTeleporterOptions()
    local list = {}
    local worlds = Workspace:FindFirstChild("Worlds")
    if not worlds then return list end

    for _, worldName in ipairs({"1", "2", "3", "4"}) do
        local world = worlds:FindFirstChild(worldName)
        local teleporter = world and world:FindFirstChild("Teleporter")
        if teleporter then
            table.insert(list, worldName)
        end
    end

    return list
end

local function GetSelectedTeleporterPart()
    local worlds = Workspace:FindFirstChild("Worlds")
    local selectedWorld = State.ExitTeleporter
    if not worlds or not selectedWorld then return nil end

    local world = worlds:FindFirstChild(selectedWorld)
    local teleporter = world and world:FindFirstChild("Teleporter")
    if not teleporter then return nil end

    if teleporter:IsA("BasePart") then
        local attr = teleporter:GetAttribute("TeleportTo")
        if typeof(attr) == "string" then
            local expectedWorld = tostring(selectedWorld)
            local prefix = expectedWorld .. "/"
            if string.sub(attr, 1, #prefix) ~= prefix then
                warn("[Trial Exit] Teleporter TeleportTo no coincide con el mundo seleccionado: " .. tostring(attr))
                return nil
            end
        end
        return teleporter
    end

    local teleporterPart = teleporter:FindFirstChildWhichIsA("BasePart")
    if teleporterPart then
        local attr = teleporterPart:GetAttribute("TeleportTo")
        if typeof(attr) == "string" then
            local expectedWorld = tostring(selectedWorld)
            local prefix = expectedWorld .. "/"
            if string.sub(attr, 1, #prefix) ~= prefix then
                warn("[Trial Exit] Teleporter TeleportTo no coincide con el mundo seleccionado: " .. tostring(attr))
                return nil
            end
        end
        return teleporterPart
    end

    return nil
end

local function GetCurrentTrialWave()
    local gui = LocalPlayer:FindFirstChild("PlayerGui")
    local raid = gui and gui:FindFirstChild("RaidGui")
    local main = raid and raid:FindFirstChild("Main")
    local wave = main and main:FindFirstChild("Wave")
    if not wave then return nil end

    if wave:IsA("TextLabel") or wave:IsA("TextBox") then
        return wave.Text
    end

    return nil
end

local function CheckTrialExit()
    local currentWave = GetCurrentTrialWave()
    if not currentWave then
        warn("[Trial Exit] No se encontró PlayerGui.RaidGui.Main.Wave")
        return
    end

    if not State.ExitWave or tostring(currentWave) ~= tostring(State.ExitWave) then
        warn("[Trial Exit] Wave actual: " .. tostring(currentWave) .. ", buscando: " .. tostring(State.ExitWave))
        return
    end

    local targetPart = GetSelectedTeleporterPart()
    if not targetPart then
        warn("[Trial Exit] No se encontró el teleporter seleccionado")
        return
    end

    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if hrp then
        hrp.CFrame = targetPart.CFrame * CFrame.new(0, 0, 3)
    end
end

local function IsEnemyGone(enemy)
    if not enemy or not enemy.Parent or not enemy:FindFirstChild("HumanoidRootPart") then
        return true
    end
    local isDead = enemy:GetAttribute("EnemyDead")
    return isDead == true
end

local function IsEnemyFinished(enemy)
    return IsEnemyGone(enemy)
end

