local function TeleportPlayerToCFrame(cframe)
    local timeout = 3 -- segundos
    local start = os.clock()
    while (os.clock() - start) <= timeout do
        local char = LocalPlayer.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        if hrp then
            hrp.CFrame = cframe
            print("[Teleport] HumanoidRootPart encontrado y teletransportado")
            return true
        end
        task.wait(0.1)
    end

    warn("[Teleport] No se encontró HumanoidRootPart tras esperar " .. tostring(timeout) .. "s")
    return false
end

local function GetTrialJoinPart()
    local targetPos = Vector3.new(1842.82227, 415.041351, -2411.81909)
