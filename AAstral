local function JoinTrial()
    print("[Trial Join] Usando teletransporte directo al part de unión")
    if not TeleportToTrialJoin() then
        warn("[Trial Join] Falló el teletransporte directo a trial")
    end
end

local function StartAutoJoinTrialLoop()
    AutoJoinTrialToken += 1
    local token = AutoJoinTrialToken

    task.spawn(function()
        while State.AutoJoinTrial and token == AutoJoinTrialToken do
            local now = os.date("*t")
            if now.min == 0 or now.min == 30 then
                local key = string.format("%04d-%02d-%02d-%02d-%02d", now.year, now.month, now.day, now.hour, now.min)
                if key ~= LastTrialJoinKey then
                    LastTrialJoinKey = key
                    -- Reintentar JoinTrial durante 6 segundos cada 2 segundos
                    local start = os.clock()
                    repeat
                        JoinTrial()
                        task.wait(2)
                    until (os.clock() - start) > 6
                end
            end

            task.wait(1)
        end
    end)
end

local function StartAutoJoinRaidLoop()
    AutoJoinRaidToken += 1
    local token = AutoJoinRaidToken

    task.spawn(function()
        while State.AutoJoinRaid and token == AutoJoinRaidToken do
            print("[Raid Join Debug] Intentando unirse a raid automáticamente...")
            TryStartRaidWithGui()
            task.wait(5)
