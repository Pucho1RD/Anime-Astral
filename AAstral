local function SimulateGuiClick(guiObject)
    if not guiObject or not guiObject:IsA("GuiObject") then
        return false
    end

    local absPos = guiObject.AbsolutePosition
    local absSize = guiObject.AbsoluteSize
    if absSize.X <= 0 or absSize.Y <= 0 then
        return false
    end

    local x = absPos.X + absSize.X / 2
    local y = absPos.Y + absSize.Y / 2 + 5
    print("[Raid Exit Debug] Simulando click en GUI en pantalla: " .. tostring(x) .. ", " .. tostring(y))
    VirtualInputManager:SendMouseButtonEvent(x, y, 0, true, game, 0)
    VirtualInputManager:SendMouseButtonEvent(x, y, 0, false, game, 0)
    return true
end

local function TryLeaveRaidWithGui()
    local gui = LocalPlayer:FindFirstChild("PlayerGui")
    local raid = gui and gui:FindFirstChild("RaidGui")
    local main = raid and raid:FindFirstChild("Main")
    local leaveButton = main and main:FindFirstChild("Leave")

    if leaveButton and leaveButton:IsA("GuiObject") then
        print("[Raid Exit Debug] Botón Leave encontrado, simulando click...")
        if SimulateGuiClick(leaveButton) then
            task.wait(0.5)
            return true
        end
    end

    warn("[Raid Exit] No se encontró PlayerGui.RaidGui.Main.Leave o no es un GuiObject")
    return false
end

local function TryStartRaidWithGui()
    local gui = LocalPlayer:FindFirstChild("PlayerGui")
    local windows = gui and gui:FindFirstChild("Windows")
    local raidTemplate = windows and windows:FindFirstChild("RaidTemplate")
    
    if not raidTemplate then
        warn("[Raid Join] No se encontró RaidTemplate")
        return false
    end

    -- Hacer visible
    raidTemplate.Visible = true
    print("[Raid Join Debug] RaidTemplate hecho visible")
    task.wait(0.3)

    -- Buscar el botón Start
    local main = raidTemplate:FindFirstChild("Main")
    local actions = main and main:FindFirstChild("Actions")
    local startButton = actions and actions:FindFirstChild("Start")

    if startButton and startButton:IsA("GuiObject") then
        print("[Raid Join Debug] Botón Start encontrado, simulando click...")
        if SimulateGuiClick(startButton) then
            task.wait(0.5)
        end
    else
        warn("[Raid Join] No se encontró Players.LocalPlayer.PlayerGui.Windows.RaidTemplate.Main.Actions.Start")
    end

    -- Ocultar de nuevo
    task.wait(0.2)
    raidTemplate.Visible = false
    print("[Raid Join Debug] RaidTemplate ocultado")
    return true
end

