local function CheckTrialExit()
    local currentRoom = GetCurrentTrialRoom()
    if not currentRoom then
        warn("[Trial Exit] No se encontró PlayerGui.TrialGui.Main.Room")
        return false
    end

    if not State.ExitWave then
        warn("[Trial Exit] No se configuró la room de salida")
        return false
    end

    local desiredRoom = NormalizeWaveValue(State.ExitWave)
    local currentRoomNumber = NormalizeRoomNumber(currentRoom)
    local desiredRoomNumber = NormalizeRoomNumber(State.ExitWave)

    if currentRoomNumber and desiredRoomNumber then
        if currentRoomNumber < desiredRoomNumber then
            warn("[Trial Exit] Room actual: " .. tostring(currentRoomNumber) .. ", buscando: " .. tostring(desiredRoomNumber))
            return false
        end
    elseif currentRoom ~= desiredRoom then
        warn("[Trial Exit] Room actual: " .. tostring(currentRoom) .. ", buscando: " .. tostring(desiredRoom))
        return false
    end

    local exitCFrame = GetTrialExitCFrame()
    if exitCFrame then
        print("[Trial Exit Debug] Usando CFrame directo para Worlds[" .. tostring(State.ExitTeleporter) .. "]")
        local char = LocalPlayer.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        if hrp then
            hrp.CFrame = exitCFrame
            return true
        end

        warn("[Trial Exit] No se encontró HumanoidRootPart para teletransportar")
        return false
    end

    local targetPart = GetSelectedTeleporterPart(State.ExitTeleporter)
    if not targetPart then
        warn("[Trial Exit] No se encontró el teleporter seleccionado")
        return false
    end

    print("[Trial Exit Debug] Teleportando a part: " .. tostring(targetPart:GetFullName()))
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if hrp then
        hrp.CFrame = targetPart.CFrame * CFrame.new(0, 0, 3)
        return true
    end

    warn("[Trial Exit] No se encontró HumanoidRootPart para teletransportar")
    return false
end

