local function SimulateGuiClick(guiObject, useAbsolutePosition)
    if not guiObject or not guiObject:IsA("GuiButton") then
        return false
    end

    local absPos = guiObject.AbsolutePosition
    local absSize = guiObject.AbsoluteSize
    if absSize.X <= 0 or absSize.Y <= 0 then
        return false
    end

    print("[SimulateGuiClick] Posición esquina:", absPos.X, absPos.Y)
    print("[SimulateGuiClick] Tamaño:", absSize.X, absSize.Y)

    -- 🛠️ CONTROL DE BAJADA (OFFSET EN PÍXELES)
    -- Ajusta este valor si necesitas que baje más (ej: 40, 50, etc.)
    local offsetY = 36

    -- Cambiamos las multiplicaciones por el cálculo del centro real más el ajuste vertical
    local x = absPos.X + absSize.X / 2
    local y = absPos.Y + absSize.Y / 2 + offsetY

    if useAbsolutePosition and ((typeof(useAbsolutePosition) == "Vector2") or type(useAbsolutePosition) == "table") and useAbsolutePosition.X and useAbsolutePosition.Y then
        x = useAbsolutePosition.X + absSize.X / 2
        y = useAbsolutePosition.Y + absSize.Y / 2 + offsetY
    end

    local camera = workspace.CurrentCamera
    local viewport = (camera and camera.ViewportSize) or Vector2.new(1920, 1080)
    if type(math.clamp) == "function" then
        x = math.clamp(x, 1, viewport.X - 1)
        y = math.clamp(y, 1, viewport.Y - 1)
    else
        if x < 1 then x = 1 elseif x > viewport.X - 1 then x = viewport.X - 1 end
        if y < 1 then y = 1 elseif y > viewport.Y - 1 then y = viewport.Y - 1 end
    end

    print("[SimulateGuiClick] Intentando click físico modificado abajo:", x, y, "viewport:", viewport)
    pcall(function()
        print(">>> ENVIANDO MOVIMIENTO DE MOUSE A:", x, y)
        VirtualInputManager:SendMouseMoveEvent(x, y, game, 0)
        task.wait(0.03)
        print(">>> ENVIANDO MOUSE DOWN")
        VirtualInputManager:SendMouseButtonEvent(x, y, 0, true, game, 0)
        task.wait(0.03)
        print(">>> ENVIANDO MOUSE UP - CLICK COMPLETADO")
        VirtualInputManager:SendMouseButtonEvent(x, y, 0, false, game, 0)
    end)

    local function tryFireSignal()
        if type(firesignal) == "function" then
            return pcall(firesignal, guiObject.MouseButton1Click)
        end
        return false
    end

    local function tryGetConnections()
        if type(getconnections) == "function" then
            local conns = getconnections(guiObject.MouseButton1Click)
            if type(conns) == "table" then
                for _, conn in ipairs(conns) do
                    if type(conn.Function) == "function" then
                        local ok = pcall(conn.Function, guiObject)
                        if ok then
                            return true
                        end
                    end
                end
            end
        end
        return false
    end

    local function tryGuiService()
        local GuiService = game:GetService("GuiService")
        if GuiService and typeof(GuiService.SelectedObject) ~= "nil" then
            return pcall(function()
                GuiService.SelectedObject = guiObject
            end)
        end
        return false
    end

    if tryFireSignal() then
        return true
    end
    if tryGetConnections() then
        return true
    end
    if tryGuiService() then
        return true
    end

    return true
end

