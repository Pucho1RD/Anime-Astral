            {
                BridgeTuplePayload = true,
                Payload = {
                    "Create",
                    worldKey,
                    n = 2,
                },
            },
            "&",
        },
    }

    local argsWith = {
        {
            {
                __BridgeTuplePayload__ = true,
                Payload = {
                    "Create",
                    worldKey,
                    n = 2,
                },
            },
            "&",
        },
    }

    remote:FireServer(unpack(argsNormal))
