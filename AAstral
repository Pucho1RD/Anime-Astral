local function TryJoinDefense()
    local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
    local defenseGui = playerGui and playerGui:FindFirstChild("DefenseGui")

    -- Comprobar si la GUI de Defense ya está marcada como Enabled (evitar abrir template)
    if defenseGui then
        -- Propiedad `.Enabled` en ScreenGui
        if defenseGui.Enabled == true then
            print("[Defense] DefenseGui.Enabled == true, ya activo")
            return false
        end

        -- Atributo 'Enabled' en el propio ScreenGui
        if typeof(defenseGui.GetAttribute) == "function" then
            local dgAttr = defenseGui:GetAttribute("Enabled")
            if dgAttr == true then
                print("[Defense] DefenseGui attribute Enabled == true, ya activo")
                return false
            end
        end

        -- Comprobar Data.Enabled dentro de la GUI (puede ser BoolValue o atributo)
        local data = defenseGui:FindFirstChild("Data")
        if data then
            local enabledChild = data:FindFirstChild("Enabled")
            if enabledChild and enabledChild:IsA("BoolValue") and enabledChild.Value == true then
                print("[Defense] DefenseGui.Data.Enabled == true, ya activo")
                return false
            end
            if typeof(data.GetAttribute) == "function" then
                local attr = data:GetAttribute("Enabled")
                if attr == true then
                    print("[Defense] DefenseGui.Data.Enabled attribute == true, ya activo")
                    return false
                end
            end
        end
    end

    local windows = playerGui and playerGui:FindFirstChild("Windows")
    local defTemplate = windows and windows:FindFirstChild("DefenseTemplate")
    if not defTemplate then
        warn("[Defense] No se encontró Windows.DefenseTemplate en PlayerGui")
        return false
    end

    -- Abrir la interfaz, intentar click en el Start y cerrarla rápidamente
    print("[Defense] DefenseTemplate encontrado, abriendo para enviar click Start")
    defTemplate.Visible = true
    task.wait(0.35)

    local main = defTemplate:FindFirstChild("Main")
    local actions = main and main:FindFirstChild("Actions")
    local startButton = actions and actions:FindFirstChild("Start", true)
    if not startButton then
        startButton = actions and actions:FindFirstChildWhichIsA("GuiButton", true)
    end
    local clicked = false

    if startButton then
        local absPos = startButton.AbsolutePosition
        local absSize = startButton.AbsoluteSize
        local centerPos = Vector2.new(absPos.X + absSize.X / 2, absPos.Y + absSize.Y / 2)
        print("[Defense] Start ImageButton encontrado, Name:", startButton.Name, "ClassName:", startButton.ClassName, "AbsolutePosition:", absPos, "Size:", absSize, "ClickCenter:", centerPos)
        pcall(function()
            startButton:Activate()
        end)
        clicked = true

        -- También intentar click físico por si Activate() no basta
        if typeof(SimulateGuiClick) == "function" then
            SimulateGuiClick(startButton, absPos)
        else
            VirtualInputManager:SendMouseMoveEvent(centerPos.X, centerPos.Y, game, 0)
            task.wait(0.03)
            VirtualInputManager:SendMouseButtonEvent(centerPos.X, centerPos.Y, 0, true, game, 0)
            task.wait(0.03)
            VirtualInputManager:SendMouseButtonEvent(centerPos.X, centerPos.Y, 0, false, game, 0)
        end
    else
        warn("[Defense] No se encontró Start ni GuiButton en Actions dentro de DefenseTemplate")
    end

    if clicked then
        print("[Defense] Click Start enviado en DefenseTemplate")

        -- Esperar hasta que DefenseGui se marque como activo, con timeout
        local activated = false
        local startTime = os.clock()
        local timeout = 2 -- segundos
        repeat
            local dgCheck = playerGui and playerGui:FindFirstChild("DefenseGui")
            if dgCheck then
                if dgCheck.Enabled == true then
                    activated = true
                    break
                end
                if typeof(dgCheck.GetAttribute) == "function" and dgCheck:GetAttribute("Enabled") == true then
                    activated = true
                    break
                end
                local dataCheck = dgCheck:FindFirstChild("Data")
                if dataCheck then
                    local enabledChild = dataCheck:FindFirstChild("Enabled")
                    if enabledChild and enabledChild:IsA("BoolValue") and enabledChild.Value == true then
                        activated = true
                        break
                    end
                    if typeof(dataCheck.GetAttribute) == "function" and dataCheck:GetAttribute("Enabled") == true then
                        activated = true
                        break
                    end
                end
            end
            task.wait(0.15)
        until (os.clock() - startTime) > timeout

        if activated then
            print("[Defense] DefenseGui activado tras click, cerrando template")
        else
            warn("[Defense] Tras el click no se detectó activación de DefenseGui (timeout), cerrando template")
        end
    else
        warn("[Defense] No se pudo simular el click en Start")
    end

    defTemplate.Visible = false
    return true
end

local function StartAutoJoinDefenseLoop()
    AutoJoinDefenseToken += 1
    local token = AutoJoinDefenseToken

    task.spawn(function()
        print("[Defense] StartAutoJoinDefenseLoop iniciado")

        -- Intento inmediato al activar (comprobando Data.Enabled)
        if State.AutoJoinDefense and token == AutoJoinDefenseToken then
            print("[Defense] Intento inmediato de JoinDefense al activar toggle")
            pcall(TryJoinDefense)
        end

        while State.AutoJoinDefense and token == AutoJoinDefenseToken do
                local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
                local dg = playerGui and playerGui:FindFirstChild("DefenseGui")
                local isActive = false
                if dg then
                    -- Revisar propiedad ScreenGui.Enabled
                    if dg.Enabled == true then
                        isActive = true
                    end

                    -- Revisar atributo Enabled en el ScreenGui
                    if not isActive and typeof(dg.GetAttribute) == "function" then
                        local dgAttr = dg:GetAttribute("Enabled")
                        if dgAttr == true then isActive = true end
                    end

                    -- Revisar Data.Enabled como antes
                    if not isActive then
                        local data = dg:FindFirstChild("Data")
                        if data then
                            local enabledChild = data:FindFirstChild("Enabled")
                            if enabledChild and enabledChild:IsA("BoolValue") then
                                isActive = enabledChild.Value
                            elseif typeof(data.GetAttribute) == "function" then
                                local attr = data:GetAttribute("Enabled")
                                if attr ~= nil then isActive = attr end
                            end
                        end
                    end
                end

            if not isActive then
                print("[Defense] DefenseGui no activo, intentando JoinDefense...")
                pcall(TryJoinDefense)
            else
                print("[Defense] DefenseGui activo (Data.Enabled=true), omitiendo join")
            end

            task.wait(3)
        end
    end)
