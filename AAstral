local function RunAutoRaidFarm()
    RaidFarmToken += 1
    local token = RaidFarmToken

    task.spawn(function()
        while State.RaidAutoFarm and token == RaidFarmToken do
            if State.RaidAutoFarmPaused or not CanRunGamemode("Raid") then
                task.wait(0.1)
                continue
            end

            local enemies = GetRaidEnemies()
            if #enemies == 0 then
                task.wait(0.1)
                continue
            end

            print("[Raid Farm] Enemigos detectados")
            task.wait(0.1)

            if not State.RaidAutoFarm or token ~= RaidFarmToken or State.RaidAutoFarmPaused or not CanRunGamemode("Raid") then
                continue
            end

            local target = nil
            for _, enemy in ipairs(enemies) do
                if not IsEnemyFinished(enemy) then
                    target = enemy
                    break
                end
            end

            if not target then
                task.wait(0.1)
                continue
            end

            local char = LocalPlayer.Character
            local hrp = char and char:FindFirstChild("HumanoidRootPart")
            local targetHRP = target and target:FindFirstChild("HumanoidRootPart")
            if not hrp or not targetHRP then
                task.wait(0.1)
                continue
            end

            hrp.CFrame = targetHRP.CFrame * CFrame.new(0, 0, 3)

            repeat
                task.wait(0.05)
            until not State.RaidAutoFarm or token ~= RaidFarmToken or State.RaidAutoFarmPaused or not CanRunGamemode("Raid") or IsEnemyFinished(target)

            task.wait(0.1)
        end
    end)
end

