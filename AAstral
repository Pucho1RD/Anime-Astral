local function IsDefenseGuiActive()
    local gui = LocalPlayer:FindFirstChild("PlayerGui")
    local defenseGui = gui and gui:FindFirstChild("DefenseGui")
    if not defenseGui then
        return false
    end

    if defenseGui.Enabled == true then
        return true
    end
    if typeof(defenseGui.GetAttribute) == "function" and defenseGui:GetAttribute("Enabled") == true then
        return true
    end

    local data = defenseGui:FindFirstChild("Data")
    if data then
        local enabledChild = data:FindFirstChild("Enabled")
        if enabledChild and enabledChild:IsA("BoolValue") and enabledChild.Value == true then
            return true
        end
        if typeof(data.GetAttribute) == "function" and data:GetAttribute("Enabled") == true then
            return true
        end
    end

    return false
end

