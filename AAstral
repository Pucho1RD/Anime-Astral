local FarmToken = 0
local RaidFarmToken = 0

local function TeleportToEnemy(enemy)
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    local targetHRP = enemy and enemy:FindFirstChild("HumanoidRootPart")
    if hrp and targetHRP then
        hrp.CFrame = targetHRP.CFrame * CFrame.new(0, 0, 3)
    end
end

local function RunAutoFarm()
    FarmToken += 1
    local myToken = FarmToken

    task.spawn(function()
        while State.AutofarmEnabled and myToken == FarmToken do
            local enemies = GetAliveEnemies()
            if #enemies == 0 then
                task.wait(0.5)
                continue
            end

            for _, enemy in ipairs(enemies) do
                if not State.AutofarmEnabled or myToken ~= FarmToken then break end

                while State.AutofarmEnabled and myToken == FarmToken and not IsEnemyFinished(enemy) do
                    TeleportToEnemy(enemy)
                    task.wait(0.05)
                end

                task.wait(0.2) -- Pequeña pausa antes del siguiente spawn
            end
        end
    end)
end

local function RunRaidAutoFarm()
    RaidFarmToken += 1
    local myToken = RaidFarmToken

    task.spawn(function()
        while State.RaidAutoFarm and myToken == RaidFarmToken do
            local enemies = GetRaidAliveEnemies()
            if #enemies == 0 then
                task.wait(0.5)
                continue
            end

            for _, enemy in ipairs(enemies) do
                if not State.RaidAutoFarm or myToken ~= RaidFarmToken then break end

                while State.RaidAutoFarm and myToken == RaidFarmToken and not IsEnemyFinished(enemy) do
                    TeleportToEnemy(enemy)
                    task.wait(0.05)
                end

                task.wait(0.2)
            end
        end
    end)
end

