local function GetAliveEnemies()
    local list = {}
    if not State.SelectedMap or not State.SelectedEnemy then return list end

    local worlds = Workspace:FindFirstChild("Worlds")
    local map = worlds and worlds:FindFirstChild(State.SelectedMap)
    local folder = map and map:FindFirstChild("Enemies")
    if not folder then return list end

    for _, enemy in ipairs(folder:GetChildren()) do
        if enemy:IsA("Model") and enemy.Name == State.SelectedEnemy and enemy:FindFirstChild("HumanoidRootPart") then
            local isDead = enemy:GetAttribute("EnemyDead")
            if isDead ~= true then
                table.insert(list, enemy)
            end
        end
    end
    return list
end

local FarmToken = 0

local function TeleportToEnemy(enemy)
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    local targetHRP = enemy and enemy:FindFirstChild("HumanoidRootPart")
    if hrp and targetHRP then
        hrp.CFrame = targetHRP.CFrame * CFrame.new(0, 0, 3)
    end
end

local function RunAutoFarm()
    FarmToken += 1
    local myToken = FarmToken

    task.spawn(function()
        while State.AutofarmEnabled and myToken == FarmToken do
            local enemies = GetAliveEnemies()
            if #enemies == 0 then
                task.wait(0.5)
                continue
            end

            for _, enemy in ipairs(enemies) do
                if not State.AutofarmEnabled or myToken ~= FarmToken then break end

                while State.AutofarmEnabled and myToken == FarmToken and not IsEnemyFinished(enemy) do
                    TeleportToEnemy(enemy)
                    task.wait(0.05)
                end

                task.wait(0.2) -- Pequeña pausa antes del siguiente spawn
            end
        end
    end)
end

local BestPowerRunning = false
local AutoJoinTrialToken = 0
local LastTrialJoinKey = nil
local AutoExitTrialToken = 0
local LastTrialExitKey = nil

local function JoinTrial()
    local args = {
        [1] = {
            [1] = {
                ["BridgeTuplePayload"] = true,
                ["Payload"] = {
                    [1] = "Join",
                    [2] = "Easy",
                    ["n"] = 2,
                },
            },
            [2] = "\160",
        },
    }

    local bridge = ReplicatedStorage:FindFirstChild("BridgeNet2")
    local remote = bridge and bridge:FindFirstChild("dataRemoteEvent")
    if remote and typeof(remote.FireServer) == "function" then
        remote:FireServer(unpack(args))
    end
end

local function StartAutoJoinTrialLoop()
    AutoJoinTrialToken += 1
    local token = AutoJoinTrialToken

    task.spawn(function()
        while State.AutoJoinTrial and token == AutoJoinTrialToken do
            local now = os.date("*t")
            if now.hour == 0 and (now.min == 0 or now.min == 30) then
                local key = string.format("%04d-%02d-%02d-%02d-%02d", now.year, now.month, now.day, now.hour, now.min)
                if key ~= LastTrialJoinKey then
                    LastTrialJoinKey = key
                    JoinTrial()
                end
            end

            task.wait(5)
        end
    end)
end

local function StartAutoExitTrialLoop()
    AutoExitTrialToken += 1
    local token = AutoExitTrialToken

    task.spawn(function()
        while State.AutoExitTrial and token == AutoExitTrialToken do
            if State.ExitWave and State.ExitTeleporter then
                local currentWave = GetCurrentTrialWave()
                if currentWave and tostring(currentWave) == tostring(State.ExitWave) then
                    local key = string.format("%s-%s", tostring(currentWave), tostring(State.ExitTeleporter))
                    if key ~= LastTrialExitKey then
                        LastTrialExitKey = key
                        CheckTrialExit()
                    end
                end
            end
            task.wait(2)
        end
    end)
end

local function BestPower()
    if BestPowerRunning then return end
    BestPowerRunning = true

    task.spawn(function()
        while BestPowerRunning do
            local args = {
                [1] = {
                    [1] = "Power",
                    [2] = "<"
                }
            }

            ReplicatedStorage.BridgeNet2.dataRemoteEvent:FireServer(unpack(args))
            task.wait(120)
        end
    end)
end

