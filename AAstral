local function GetMaps()
    local list = {}
    local worlds = Workspace:FindFirstChild("Worlds")
    if not worlds then return list end

    for _, map in ipairs(worlds:GetChildren()) do
        if map:IsA("Folder") or map:IsA("Model") then
            table.insert(list, map.Name)
        end
    end

    table.sort(list)
    return list
end

local function GetEnemies(mapName)
    local list = {}
    local worlds = Workspace:FindFirstChild("Worlds")
    local map = worlds and worlds:FindFirstChild(mapName)
    local folder = map and map:FindFirstChild("Enemies")
    if not folder then return list end

    local seen = {}
    for _, enemy in ipairs(folder:GetChildren()) do
        if enemy:IsA("Model") and enemy:FindFirstChild("HumanoidRootPart") then
            local name = enemy.Name
            if not seen[name] then
                table.insert(list, name)
                seen[name] = true
            end
        end
    end

    table.sort(list)
    return list
end

