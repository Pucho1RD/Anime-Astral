TrialTab:CreateToggle({
    Name = "AutoFarm Trial",
    CurrentValue = false,
    Callback = function(Value)
        State.TrialEnabled = Value
        if Value then
            task.spawn(function()
                -- Buscamos la carpeta de forma segura pero directa
                local arenas = Workspace:WaitForChild("TimeTrialArenas", 5)
                local easyArena = arenas and arenas:WaitForChild("Easy", 5)
                local TrialFolder = easyArena and easyArena:FindFirstChild("Enemies")
                
                if not TrialFolder then 
                    print("[AutoFarm Error] No se encontró la carpeta de enemigos de la Trial.")
                    return 
                end
                
                while State.TrialEnabled do
                    local target = nil
                    
                    -- Buscamos el objetivo más cercano o el primero disponible
                    for _, enemy in pairs(TrialFolder:GetChildren()) do
                        if enemy:FindFirstChild("HumanoidRootPart") then
                            -- Opcional: Validar que tenga vida real si el juego usa ese atributo en la trial
                            local health = enemy:GetAttribute("HealthReal")
                            if health == nil or health > 0 then
                                target = enemy
                                break
                            end
                        end
                    end
                    
                    if target and target:FindFirstChild("HumanoidRootPart") then
                        local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                        if hrp then
                            hrp.CFrame = target.HumanoidRootPart.CFrame * CFrame.new(0, 0, 3)
                        end
                        
                        -- Reducimos el tiempo de chequeo a 0.01 (bucle ultra rápido)
                        -- El bucle se rompe en el instante exacto en que el NPC muere o desaparece
                        repeat 
                            task.wait(0.01) 
                        until not State.TrialEnabled or not target.Parent or not target:FindFirstChild("HumanoidRootPart")
                        
                        -- ELIMINAMOS el task.wait(0.1) que estaba aquí para que el TP al siguiente sea inmediato
                    else
                        -- Si no hay enemigos en la arena, espera un parpadeo para volver a escanear (evita lag)
                        task.wait(0.05)
                    end
                end
            end)
        end
    end,
})

