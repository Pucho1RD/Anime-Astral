end

local function StartAutoExitTrialLoop()
    AutoExitTrialToken += 1
    local token = AutoExitTrialToken

    task.spawn(function()
        while State.AutoExitTrial and token == AutoExitTrialToken do
            if State.ExitWave and State.ExitTeleporter then
                local currentRoom = GetCurrentTrialRoom()
                local desiredRoom = NormalizeWaveValue(State.ExitWave)
                local currentRoomNumber = NormalizeRoomNumber(currentRoom)
                local desiredRoomNumber = NormalizeRoomNumber(State.ExitWave)
                print("[Trial Exit Debug] Room actual: " .. tostring(currentRoom) .. " (" .. tostring(currentRoomNumber) .. "), room deseada: " .. tostring(desiredRoom) .. " (" .. tostring(desiredRoomNumber) .. ")")
                if currentRoom and ((currentRoomNumber and desiredRoomNumber and currentRoomNumber >= desiredRoomNumber) or currentRoom == desiredRoom) then
                    if CheckTrialExit() then
                        warn("[Trial Exit] Salida ejecutada en room " .. tostring(currentRoom))
                        State.AutoExitTrial = false
                        break
                    end
                end
            end
            task.wait(2)
        end
    end)
end

local function StopRaidAutoFarm()
