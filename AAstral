local function GetDefenseEnemies()
    local list = {}
    local defenseArenas = Workspace:FindFirstChild("DefenseArenas")
    local world4 = defenseArenas and defenseArenas:FindFirstChild("World4")
    local folder = world4 and world4:FindFirstChild("Enemies")
    if not folder then
        return list
    end

    for _, enemy in ipairs(folder:GetChildren()) do
        if enemy:IsA("Model") and enemy:FindFirstChild("HumanoidRootPart") then
            local isDead = enemy:GetAttribute("EnemyDead")
            if isDead ~= true then
                table.insert(list, enemy)
            end
        end
    end

    return list
end

local function RunAutoDefense()
    AutoDefenseToken += 1
    local token = AutoDefenseToken

    task.spawn(function()
        while State.AutoDefense and token == AutoDefenseToken do
            local enemies = GetDefenseEnemies()
            if #enemies == 0 then
                task.wait(0.5)
                continue
            end

            for _, enemy in ipairs(enemies) do
                if not State.AutoDefense or token ~= AutoDefenseToken then
                    break
                end

                -- Mantener teletransportándose continuamente cerca del NPC mientras se mueve
                while State.AutoDefense and token == AutoDefenseToken and enemy and enemy.Parent and enemy:GetAttribute("EnemyDead") ~= true do
                    local char = LocalPlayer.Character
                    local hrp = char and char:FindFirstChild("HumanoidRootPart")
                    local targetHRP = enemy and enemy:FindFirstChild("HumanoidRootPart")

                    if hrp and targetHRP then
                        -- Colocar ligeramente detrás del NPC para seguirlo sin superponer
                        local offset = Vector3.new(0, 0, 3)
                        local targetPos = targetHRP.Position
                        -- Añadir pequeña elevación para evitar quedar dentro del suelo
                        local safePos = targetPos + Vector3.new(0, 2, 0) - (targetHRP.CFrame.LookVector * 2)
                        hrp.CFrame = CFrame.new(safePos, targetPos)
                    end

                    task.wait(0.08)
                end

                task.wait(0.2)
            end
        end
    end)
end

